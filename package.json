{
    "name": "robinpath-engine",
    "version": "1.62.0",
    "private": true,
    "type": "module",
    "description": "Standalone binary builder for the RobinPath scripting language",
    "scripts": {
        "build:bundle": "node build.js",
        "build:blob": "node --experimental-sea-config sea-config.json",
        "build": "npm run build:bundle && npm run build:blob",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/"
    },
    "bin": {
        "robinpath": "cli-entry.js",
        "rp": "cli-entry.js"
    },
    "dependencies": {
        "@wiredwp/robinpath": "^0.30.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.5.0",
        "eslint": "^10.0.3",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    }
}
