{
    "name": "@robinpath/cli",
    "version": "2.4.0",
    "description": "AI-powered scripting CLI — automate anything from your terminal",
    "type": "module",
    "license": "MIT",
    "bin": {
        "robinpath": "dist/cli.mjs",
        "rp": "dist/cli.mjs"
    },
    "files": [
        "dist/cli.mjs",
        "modules/"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "node build.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "cli",
        "ai",
        "automation",
        "scripting",
        "robinpath",
        "terminal",
        "assistant"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/wiredwp/robinpath-cli.git"
    },
    "homepage": "https://dev.robinpath.com",
    "dependencies": {
        "@wiredwp/robinpath": "^0.30.1",
        "ink": "^6.8.0",
        "ink-spinner": "^5.0.0",
        "ink-text-input": "^6.0.0",
        "react": "^19.2.4",
        "react-devtools-core": "^7.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "eslint": "^10.0.3",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    }
}
